{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/destinatario",  "destination": "/portal_destinatario.html" },
    { "source": "/transportista", "destination": "/portal_transportista.html" },
    { "source": "/corredor",      "destination": "/portal_corredor.html" },
    { "source": "/app",           "destination": "/agro_app.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
